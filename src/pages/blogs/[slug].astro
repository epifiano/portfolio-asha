---
import { getCollection } from 'astro:content';
import '../../index.css';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const blogsEntries = await getCollection('blogs');
  return blogsEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{entry.data.title} — Javier Rojas</title>
    <meta name="description" content={entry.data.description} />
    <link rel="canonical" href={`https://javierrojas.dev/blogs/${entry.slug}`} />
    <meta property="og:title" content={`${entry.data.title} — Javier Rojas`} />
    <meta property="og:description" content={entry.data.description} />
    <meta property="og:url" content={`https://javierrojas.dev/blogs/${entry.slug}`} />
    <meta property="og:type" content="article" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${entry.data.title} — Javier Rojas`} />
    <meta name="twitter:description" content={entry.data.description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300..700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="p-4 md:p-8 lg:p-12 bg-background text-font">
    <Header />
    <main class="mx-auto max-w-5xl py-8">
      <article class="prose prose-invert text-font max-w-none">
        <Content />
      </article>
      <div class="mt-8">
        <a href="/" class="underline italic font-serif">← Volver al inicio</a>
      </div>
    </main>
    <Footer />
  </body>
</html>
